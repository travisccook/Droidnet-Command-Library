          "max": 32767
        }
      },
      "commands": [
        {
          "id": "flthy.led.leia",
          "name": "Leia",
          "group": "LED Effects",
          "safety": "cosmetic",
          "encoder": "template",
          "template": "{designator}001",
          "params": [
            { "name": "designator", "enum": "flthy.designator", "required": true }
          ],
          "supportsDuration": true,
          "examples": ["F001", "A001|30"],
          "commentLabel": "Flthy Leia"
        },
        {
          "id": "flthy.led.colorproj",
          "name": "Color Projector",
          "group": "LED Effects",
          "safety": "cosmetic",
