          "params": [
            { "name": "designator", "enum": "flthy.designator", "required": true },
            { "name": "color", "enum": "flthy.color", "default": "5" }
          ],
          "supportsDuration": true,
          "examples": ["F0025", "A0023|20"],
          "commentLabel": "Flthy color projector"
