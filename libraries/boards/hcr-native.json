  "components": [
    {
      "id": "hcr-native",
      "name": "HCR Vocalizer (native <…>)",
      "kind": "device-native",
      "confidence": "high",
      "vendor": "Human-Cyborg Relations",
      "firmware": "HCR official command API",
      "routing": {
        "class": "broadcast",
        "nativeWrapper": "angle",
        "durationSuffix": {
          "supported": false
        },
        "notes": "All commands wrapped in <...>; chain via comma <a,b> or back-to-back <a><b>. Transport Serial/UART/I2C. Distinct from the wcb-hcr ;H verb book."
      },
      "commands": [
        {
          "id": "hcr.native.stimulus",
          "name": "Emotional Stimulus",
          "safety": "cosmetic",
          "encoder": "template",
          "template": "<S{emotion}{intensity}>",
          "params": [
            {
              "name": "emotion",
              "enum": "hcr.emotion",
              "required": true
            },
            {
              "name": "intensity",
              "enum": "hcr.intensity",
              "required": true
            }
          ],
          "examples": [
            "<SH1>",
            "<SM0>"
          ],
          "commentLabel": "HCR stimulus",
          "category": "Sound"
        },
        {
          "id": "hcr.native.overload",
          "name": "Overload / Electrocution",
          "safety": "cosmetic",
          "encoder": "template",
          "template": "<SE>",
          "params": [],
          "examples": [
            "<SE>"
          ],
          "commentLabel": "HCR overload",
          "category": "Sound"
        },
        {
          "id": "hcr.native.muse",
          "name": "Muse Enable/Disable/Toggle",
          "safety": "cosmetic",
          "encoder": "template",
          "template": "<M{state}>",
          "params": [
            {
              "name": "state",
              "enum": "hcr.museState",
              "required": true
            }
          ],
          "examples": [
            "<M1>",
            "<M0>",
            "<MT>"
          ],
          "commentLabel": "HCR muse",
          "category": "Muse"
        },
        {
          "id": "hcr.native.museSingle",
          "name": "Trigger Single Musing",
          "safety": "cosmetic",
          "encoder": "template",
          "template": "<MM>",
          "params": [],
          "examples": [
            "<MM>"
          ],
          "commentLabel": "HCR muse once",
          "category": "Muse"
        },
        {
          "id": "hcr.native.museMinGap",
          "name": "Muse Min Gap (s)",
          "safety": "cosmetic",
          "encoder": "template",
          "template": "<MN{seconds}>",
          "params": [
            {
              "name": "seconds",
              "type": "int",
              "min": 0,
              "required": true
            }
          ],
          "examples": [
            "<MN5>"
          ],
          "commentLabel": "HCR muse min gap",
          "category": "Muse"
        },
        {
          "id": "hcr.native.museMaxGap",
          "name": "Muse Max Gap (s)",
          "safety": "cosmetic",
          "encoder": "template",
          "template": "<MX{seconds}>",
          "params": [
            {
              "name": "seconds",
              "type": "int",
              "min": 0,
              "required": true
            }
          ],
          "examples": [
            "<MX30>"
          ],
          "commentLabel": "HCR muse max gap",
          "category": "Muse"
        },
        {
          "id": "hcr.native.playWav",
          "name": "Play WAV File",
          "safety": "cosmetic",
          "encoder": "template",
          "template": "<C{channel}{file}>",
          "params": [
            {
              "name": "channel",
              "enum": "hcr.channel",
              "required": true
            },
            {
              "name": "file",
              "type": "int",
              "min": 0,
              "max": 9999,
              "pad": 4,
              "required": true
            }
          ],
          "examples": [
            "<CA0025>",
            "<CB0009>"
          ],
          "commentLabel": "HCR play WAV",
          "category": "Sound"
        },
        {
          "id": "hcr.native.playWavRandom",
          "name": "Play Random WAV (range)",
          "safety": "cosmetic",
          "encoder": "template",
          "template": "<C{channel}{fileFrom}C{fileTo}>",
          "params": [
            {
              "name": "channel",
              "enum": "hcr.channel",
              "required": true
            },
            {
              "name": "fileFrom",
              "type": "int",
              "min": 0,
              "max": 9999,
              "pad": 4,
              "required": true
            },
            {
              "name": "fileTo",
              "type": "int",
              "min": 0,
              "max": 9999,
              "pad": 4,
              "required": true
            }
          ],
          "examples": [
            "<CB0003C0185>"
          ],
          "commentLabel": "HCR play random WAV",
          "category": "Sound"
        },
        {
          "id": "hcr.native.stop",
          "name": "Stop",
          "safety": "cosmetic",
          "encoder": "template",
          "template": "<PS{target}>",
          "params": [
            {
              "name": "target",
              "enum": "hcr.stopTarget",
              "required": true
            }
          ],
          "examples": [
            "<PSV>",
            "<PSG>"
          ],
          "commentLabel": "HCR stop",
          "category": "Sound"
        },
