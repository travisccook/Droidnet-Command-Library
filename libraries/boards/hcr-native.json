              "required": true
            },
            {
              "name": "level",
              "type": "int",
              "min": 0,
              "max": 100,
              "required": true
            }
          ],
          "examples": [
            "<PVV100>",
            "<PVA50>"
          ],
          "commentLabel": "HCR volume",
          "category": "Sound"
        },
        {
