          "safety": "movement",
          "encoder": "template",
          "template": "*ST{target}",
          "params": [
            { "name": "target", "enum": "md.holoTarget", "default": "00", "required": true }
          ],
          "examples": ["*ST00", "*ST01"],
          "commentLabel": "Holo {target} reset",
          "category": "Lighting"
        },
        {
          "id": "md.holo.hold",
          "name": "Holo Hold (stop, keep light)",
          "safety": "movement",
          "encoder": "template",
          "template": "*HD{target}",
          "params": [
            { "name": "target", "enum": "md.holoTarget", "default": "00", "required": true }
          ],
          "examples": ["*HD00", "*HD01"],
          "commentLabel": "Holo {target} hold",
          "category": "Lighting"
        },
        {
          "id": "md.hp.light",
          "name": "On-board HP Light (seconds)",
          "safety": "cosmetic",
          "encoder": "template",
          "template": "*H{target}{seconds}",
          "params": [
            { "name": "target", "enum": "md.hpTarget", "default": "0", "required": true },
            { "name": "seconds", "type": "int", "min": 0, "max": 99, "pad": 2, "required": true }
          ],
          "examples": ["*H005", "*H199"],
          "commentLabel": "HP {target} light {seconds}s",
          "category": "Lighting"
        },
        {
          "id": "md.hp.flicker",
          "name": "On-board HP Flicker (seconds)",
          "safety": "cosmetic",
          "encoder": "template",
          "template": "*F{target}{seconds}",
          "params": [
            { "name": "target", "enum": "md.hpTarget", "default": "0", "required": true },
            { "name": "seconds", "type": "int", "min": 0, "max": 99, "pad": 2, "required": true }
          ],
          "examples": ["*F005", "*F199"],
