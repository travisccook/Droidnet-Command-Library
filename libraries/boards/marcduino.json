  "components": [
    {
      "id": "marcduino",
      "name": "MarcDuino (dome/body master)",
      "kind": "device-native",
      "confidence": "high",
      "vendor": "Marc Verdiell (CuriousMarc)",
      "firmware": "MarcDuino command reference (curiousmarc.com)",
      "routing": {
        "class": "broadcast",
        "nativeWrapper": "none",
        "durationSuffix": { "supported": false },
        "notes": "Prefix-dispatched ASCII, each command CR-terminated (\\r) on the wire; chain back-to-back separated by CR. Prefixes: ':' panel/servo, '*' holo/magic panel, '$' sound, '@' logic display (JawaLite, forwarded to Teeces), '#' setup, '&' I2C. Master forwards to slave/body boards. Composer fragments omit the trailing CR (added by the transport), matching the hcr-native convention."
      },
      "categories": ["Lighting", "Movement", "Sound", "Sequences", "Config", "System"],
      "commands": [
        {
          "id": "md.seq",
          "name": "Run Sequence",
          "safety": "movement",
          "encoder": "template",
          "template": ":SE{seq}",
          "params": [
            { "name": "seq", "type": "int", "min": 0, "max": 57, "pad": 2, "required": true }
          ],
          "examples": [":SE01", ":SE08", ":SE11"],
          "commentLabel": "MarcDuino sequence",
          "category": "Sequences"
        },
        {
          "id": "md.panel.open",
          "name": "Open Panel(s)",
          "safety": "movement",
          "encoder": "template",
          "template": ":OP{panel}",
          "params": [
            { "name": "panel", "enum": "md.panel", "default": "00", "required": true }
          ],
          "examples": [":OP00", ":OP01"],
          "commentLabel": "Open panel {panel}",
          "category": "Movement"
        },
        {
          "id": "md.panel.close",
          "name": "Close Panel(s)",
          "safety": "movement",
          "encoder": "template",
          "template": ":CL{panel}",
          "params": [
            { "name": "panel", "enum": "md.panel", "default": "00", "required": true }
          ],
          "examples": [":CL00", ":CL01"],
          "commentLabel": "Close panel {panel}",
          "category": "Movement"
        },
        {
          "id": "md.panel.rc",
          "name": "Panel(s) to RC Control",
          "safety": "movement",
          "encoder": "template",
          "template": ":RC{panel}",
          "params": [
            { "name": "panel", "enum": "md.panel", "default": "00", "required": true }
          ],
          "examples": [":RC00", ":RC01"],
          "commentLabel": "Panel {panel} to RC",
          "category": "Movement"
        },
        {
          "id": "md.panel.stop",
          "name": "Panel(s) Soft Hold (servo off)",
          "safety": "movement",
          "encoder": "template",
          "template": ":ST{panel}",
          "params": [
            { "name": "panel", "enum": "md.panel", "default": "00", "required": true }
          ],
          "examples": [":ST00", ":ST01"],
          "commentLabel": "Panel {panel} soft hold",
          "category": "Movement"
        },
        {
          "id": "md.panel.hold",
          "name": "Panel(s) Hold (servo on)",
          "safety": "movement",
          "encoder": "template",
          "template": ":HD{panel}",
          "params": [
            { "name": "panel", "enum": "md.panel", "default": "00", "required": true }
          ],
          "examples": [":HD00", ":HD01"],
          "commentLabel": "Panel {panel} hold",
          "category": "Movement"
        },
        {
          "id": "md.holo.on",
