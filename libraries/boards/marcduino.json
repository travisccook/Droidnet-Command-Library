          "name": "Magic Panel On (seconds)",
          "safety": "cosmetic",
          "encoder": "template",
          "template": "*MO{seconds}",
          "params": [
            { "name": "seconds", "type": "int", "min": 0, "max": 99, "pad": 2, "required": true }
          ],
          "examples": ["*MO05", "*MO99"],
          "commentLabel": "Magic panel on {seconds}s",
          "category": "Lighting"
        },
        {
          "id": "md.magic.flicker",
          "name": "Magic Panel Flicker (seconds)",
          "safety": "cosmetic",
          "encoder": "template",
          "template": "*MF{seconds}",
          "params": [
            { "name": "seconds", "type": "int", "min": 0, "max": 99, "pad": 2, "required": true }
          ],
          "examples": ["*MF05", "*MF10"],
          "commentLabel": "Magic panel flicker {seconds}s",
          "category": "Lighting"
        },
        {
          "id": "md.sound.playTrack",
          "name": "Play Sound (bank + track)",
          "safety": "cosmetic",
          "encoder": "template",
          "template": "${bank}{track}",
          "params": [
            { "name": "bank", "enum": "md.soundBank", "default": "1", "required": true },
            { "name": "track", "type": "int", "min": 1, "max": 99, "required": true }
          ],
          "examples": ["$52", "$18"],
          "commentLabel": "Play sound {bank} · {track}",
          "category": "Sound"
        },
        {
          "id": "md.sound.playBank",
          "name": "Play Bank (first/next)",
          "safety": "cosmetic",
          "encoder": "template",
          "template": "${bank}",
          "params": [
            { "name": "bank", "enum": "md.soundBank", "default": "1", "required": true }
          ],
          "examples": ["$1", "$5"],
          "commentLabel": "Play bank {bank}",
          "category": "Sound"
        },
        {
          "id": "md.sound.macro",
          "name": "Sound Control / Preset",
          "safety": "cosmetic",
          "encoder": "template",
          "template": "${macro}",
          "params": [
            { "name": "macro", "enum": "md.soundMacro", "required": true }
          ],
          "examples": ["$R", "$S", "$L", "$c"],
          "commentLabel": "Sound {macro}",
          "category": "Sound"
        },
        {
          "id": "md.logic.effect",
          "name": "Logic Display Effect",
          "safety": "cosmetic",
          "encoder": "template",
          "template": "@{address}T{mode}",
          "params": [
            { "name": "address", "enum": "md.logicAddr", "default": "0", "required": true },
            { "name": "mode", "enum": "md.logicMode", "default": "1", "required": true }
          ],
          "examples": ["@0T1", "@0T6"],
          "commentLabel": "Logic {address} — {mode}",
          "category": "Lighting"
        },
        {
          "id": "md.logic.text",
          "name": "Logic Display Text",
          "safety": "cosmetic",
          "encoder": "template",
          "template": "@{address}M{text}",
          "params": [
            { "name": "address", "enum": "md.logicAddr", "default": "0", "required": true },
            { "name": "text", "pattern": ".+", "required": true }
          ],
          "examples": ["@3MHELLO", "@0MR2-D2"],
          "commentLabel": "Logic {address} text",
          "category": "System"
        },
        {
          "id": "md.logic.charset",
          "name": "Logic Character Set",
