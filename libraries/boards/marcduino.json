          ],
          "examples": ["@0P60", "@0P61"],
          "commentLabel": "Logic {address} charset {charset}",
          "category": "Config"
        },
        {
          "id": "md.psi.state",
          "name": "PSI State",
          "safety": "cosmetic",
          "encoder": "template",
