  "components": [
    {
      "id": "pd-magic-panel",
      "name": "PD MagicPanel",
      "kind": "device-native",
      "confidence": "community",
      "vendor": "Printed Droid",
      "firmware": "MP32-Wireless v2.2+",
      "routing": {
        "class": "broadcast",
        "nativeWrapper": "none",
        "notes": "Printed Droid Magic Panel 32 Wireless. Serial at 115200 / I2C addr 20, commands terminated with a carriage return by the transport. Wire strings here are the bare commands; the \\r terminator and any MarcDuino '%' wrapper are added by the controller (same convention as every other device-native board).",
        "durationSuffix": {
          "supported": false
        }
      },
      "categories": [
        "Patterns",
        "Lighting",
        "Text",
        "Sequences",
        "Setup",
        "Config",
        "Power"
      ],
      "commands": [
        {
          "id": "pdmp.pattern",
          "name": "Run Pattern",
          "safety": "cosmetic",
          "template": "T{pattern}",
          "params": [
            { "name": "pattern", "enum": "pd.pattern", "required": true }
          ],
          "examples": ["T57", "T21"],
          "commentLabel": "PD MP {pattern}",
          "category": "Patterns"
        },
        {
          "id": "pdmp.pattern.timed",
          "name": "Run Pattern (timed)",
          "safety": "cosmetic",
          "template": "T{pattern}:{duration}",
          "params": [
            { "name": "pattern", "enum": "pd.pattern", "required": true },
            { "name": "duration", "type": "int", "min": 1, "max": 3600, "required": true }
          ],
          "examples": ["T57:30", "T21:5"],
          "commentLabel": "PD MP {pattern} ({duration}s)",
          "category": "Patterns"
        },
        {
          "id": "pdmp.demo",
          "name": "Smart Demo",
          "safety": "cosmetic",
          "template": "DEMO",
          "examples": ["DEMO"],
          "commentLabel": "PD MP demo",
          "category": "Patterns"
        },
        {
          "id": "pdmp.brightness",
          "name": "Brightness",
          "safety": "cosmetic",
          "template": "B{level}",
          "params": [
            { "name": "level", "type": "int", "min": 0, "max": 255, "required": true }
          ],
          "examples": ["B128", "B255"],
          "commentLabel": "PD MP brightness {level}",
          "category": "Lighting"
        },
        {
          "id": "pdmp.speed",
          "name": "Speed",
          "safety": "cosmetic",
          "template": "V{speed}",
          "params": [
            { "name": "speed", "type": "int", "min": 1, "max": 100, "required": true }
          ],
          "examples": ["V50"],
          "commentLabel": "PD MP speed {speed}",
          "category": "Lighting"
        },
        {
          "id": "pdmp.color",
          "name": "Preset Color",
          "safety": "cosmetic",
          "template": "C {color}",
          "params": [
            { "name": "color", "enum": "pd.color", "required": true }
          ],
          "examples": ["C 9", "C 3"],
          "commentLabel": "PD MP color {color}",
          "category": "Lighting"
        },
        {
          "id": "pdmp.rgb",
          "name": "Custom RGB",
          "safety": "cosmetic",
          "template": "C {r},{g},{b}",
          "params": [
            { "name": "r", "type": "int", "min": 0, "max": 255, "required": true },
            { "name": "g", "type": "int", "min": 0, "max": 255, "required": true },
            { "name": "b", "type": "int", "min": 0, "max": 255, "required": true }
          ],
          "examples": ["C 255,100,0"],
          "commentLabel": "PD MP RGB {r},{g},{b}",
          "category": "Lighting"
        },
        {
          "id": "pdmp.transition",
          "name": "Transitions",
          "safety": "cosmetic",
          "template": "TRANSITION {state}",
          "params": [
            { "name": "state", "enum": "pd.toggle", "required": true }
          ],
          "examples": ["TRANSITION 1", "TRANSITION 0"],
          "commentLabel": "PD MP transitions {state}",
          "category": "Lighting"
        },
        {
          "id": "pdmp.text",
          "name": "Scroll Text",
          "safety": "cosmetic",
          "template": "TEXT:{message}",
          "params": [
            { "name": "message", "pattern": ".+", "required": true }
          ],
          "examples": ["TEXT:HELLO"],
          "commentLabel": "PD MP text: {message}",
          "category": "Text"
        },
        {
          "id": "pdmp.text.bounce",
          "name": "Bounce Text",
          "safety": "cosmetic",
          "template": "TEXT_BOUNCE:{message}",
          "params": [
            { "name": "message", "pattern": ".+", "required": true }
          ],
          "examples": ["TEXT_BOUNCE:HI"],
          "commentLabel": "PD MP bounce: {message}",
          "category": "Text"
        },
        {
          "id": "pdmp.text.save",
          "name": "Save Text Slot",
          "safety": "config",
          "template": "TEXTSAVE{slot}:{message}",
          "params": [
            { "name": "slot", "type": "int", "min": 0, "max": 9, "required": true },
            { "name": "message", "pattern": ".+", "required": true }
          ],
          "examples": ["TEXTSAVE3:HELLO"],
          "commentLabel": "PD MP save text slot {slot}",
          "category": "Text"
        },
        {
          "id": "pdmp.text.load",
          "name": "Load Text Slot",
          "safety": "cosmetic",
          "template": "TEXTLOAD{slot}",
          "params": [
            { "name": "slot", "type": "int", "min": 0, "max": 9, "required": true }
          ],
          "examples": ["TEXTLOAD3"],
          "commentLabel": "PD MP load text slot {slot}",
          "category": "Text"
        },
        {
          "id": "pdmp.font",
          "name": "Font",
          "safety": "cosmetic",
          "template": "FONT {font}",
          "params": [
            { "name": "font", "enum": "pd.font", "required": true }
          ],
          "examples": ["FONT 1", "FONT 0"],
          "commentLabel": "PD MP font {font}",
          "category": "Text"
        },
        {
          "id": "pdmp.playlist",
          "name": "Run Playlist",
          "safety": "cosmetic",
          "template": "PLAYLIST_RUN:{ids}",
          "params": [
            { "name": "ids", "label": "Pattern IDs (comma-separated)", "pattern": "[0-9]+(?:,[0-9]+)*", "required": true }
          ],
          "examples": ["PLAYLIST_RUN:1,2,3"],
          "commentLabel": "PD MP playlist {ids}",
          "category": "Sequences"
        },
        {
          "id": "pdmp.startup",
          "name": "Set Startup Pattern",
          "safety": "config",
          "template": "START {pattern}",
          "params": [
            { "name": "pattern", "enum": "pd.pattern", "required": true }
          ],
          "examples": ["START 5"],
          "commentLabel": "PD MP startup pattern {pattern}",
          "category": "Setup"
        },
        {
          "id": "pdmp.mode",
          "name": "Operating Mode",
          "safety": "cosmetic",
          "template": "P{mode}",
          "params": [
            { "name": "mode", "enum": "pd.mode", "required": true }
          ],
          "examples": ["P1", "P0"],
          "commentLabel": "PD MP mode {mode}",
          "category": "Setup"
        },
        {
          "id": "pdmp.save",
          "name": "Save Settings",
          "safety": "config",
          "template": "SAVE",
          "examples": ["SAVE"],
          "commentLabel": "PD MP save settings",
          "category": "Config"
        },
        {
          "id": "pdmp.load",
          "name": "Load Settings",
          "safety": "config",
          "template": "LOAD",
          "examples": ["LOAD"],
          "commentLabel": "PD MP load settings",
          "category": "Config"
        },
        {
          "id": "pdmp.on",
          "name": "Panel On",
          "safety": "cosmetic",
          "template": "ON",
          "examples": ["ON"],
          "commentLabel": "PD MP on",
          "category": "Power"
        },
        {
          "id": "pdmp.off",
          "name": "Panel Off",
          "safety": "cosmetic",
          "template": "OFF",
          "examples": ["OFF"],
          "commentLabel": "PD MP off",
          "category": "Power"
        }
      ]
    }
  ]
}
