  "components": [
    {
      "id": "rseries-logic",
      "name": "RSeriesLogic (Logic Displays)",
      "kind": "device-native",
      "confidence": "high",
      "firmware": "Reeltwo WLogicEngine32 (C2B5)",
      "routing": {
        "class": "broadcast",
        "nativeWrapper": "none",
        "durationSuffix": {
          "supported": false
        }
      },
      "commands": [
        {
          "id": "rseries.effect",
          "name": "Logic Effect",
          "safety": "cosmetic",
          "encoder": "rseries-le",
          "params": [
            { "name": "effect", "enum": "rseries.effect", "required": true },
            { "name": "color", "enum": "rseries.color", "default": "0" },
            { "name": "speed", "type": "int", "min": 0, "max": 9, "default": 0 },
            { "name": "seconds", "type": "int", "min": 0, "max": 99, "default": 0 },
            { "name": "target", "enum": "rseries.target", "default": "" }
          ],
          "examples": ["~RTLE51000", "~RTLE10590", "~RTLE213000"],
          "commentLabel": "Logics {target} — {effect}[ · {color}]",
          "category": "Lighting"
        },
        {
          "id": "rseries.text",
          "name": "Set Logic Text",
          "safety": "cosmetic",
          "encoder": "template",
          "template": "@{address}M{text}",
          "params": [
            { "name": "address", "enum": "logicTextAddress", "required": true },
            { "name": "text", "label": "Text", "pattern": ".+", "required": true }
          ],
          "examples": ["@1MHELLO", "@3MR2-D2"],
          "commentLabel": "Logics {address} text",
          "category": "Text"
        },
        {
          "id": "rseries.font",
          "name": "Set Logic Font",
          "safety": "cosmetic",
          "encoder": "template",
          "template": "@{address}P{font}",
          "params": [
            { "name": "address", "enum": "logicTextAddress", "required": true },
            { "name": "font", "enum": "logicFont", "default": "60" }
          ],
          "examples": ["@1P60", "@3P61"],
          "commentLabel": "Logics {address} font — {font}",
          "category": "Text"
        },
        {
          "id": "rseries.cfg.wifi",
          "name": "WiFi Enable",
          "safety": "config",
          "encoder": "template",
          "template": "#LEWIFI{state}",
          "params": [
            { "name": "state", "enum": "logicToggle", "default": "" }
          ],
          "examples": ["#LEWIFI1", "#LEWIFI0", "#LEWIFI"],
          "commentLabel": "Logics WiFi — {state}",
          "category": "Config"
        },
        {
          "id": "rseries.cfg.remote",
          "name": "Remote Enable",
          "safety": "config",
          "encoder": "template",
          "template": "#LEREMOTE{state}",
          "params": [
            { "name": "state", "enum": "logicToggle", "default": "" }
          ],
          "examples": ["#LEREMOTE1", "#LEREMOTE0", "#LEREMOTE"],
          "commentLabel": "Logics remote — {state}",
          "category": "Config"
        },
        {
          "id": "rseries.sys.restart",
          "name": "Restart",
          "safety": "config",
          "encoder": "template",
          "template": "#LERESTART",
          "params": [],
          "examples": ["#LERESTART"],
          "commentLabel": "Logics restart",
          "category": "System"
        },
        {
          "id": "rseries.sys.zero",
          "name": "Factory Reset",
          "safety": "config",
          "encoder": "template",
          "template": "#LEZERO",
          "params": [],
          "examples": ["#LEZERO"],
          "commentLabel": "Logics factory reset",
          "category": "System"
        }
      ],
      "categories": ["Lighting", "Text", "Config", "System"]
    }
  ]
}
